{
  "buildCommand": "npm install",
  "framework": "other",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],
  "regions": [
    "iad1"
  ],
  "functions": {
    "api/_player.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/_battle.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/_loot.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/_ai.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  }
}