# Copy this to .env and fill in your values.
# In Vercel dashboard: Settings → Environment Variables

# Neon PostgreSQL (required)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# AI APIs (all free tier — get at least GROQ_API_KEY for best experience)
# Groq:     https://console.groq.com     (unlimited free, fastest)
# Cerebras: https://console.cerebras.ai  (1M tokens/month free, batch)
# Gemini:   https://ai.google.dev        (1500 req/day free, fallback)
# The game works without any of these — falls back to procedural names.
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk_...
GEMINI_API_KEY=AIza...
