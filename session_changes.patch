@@ -0,0 +1,28 @@
+-- Migration 002: hero teams/parties.
+-- A player builds named teams of up to 5 heroes for battle. Additive/idempotent.
+-- Apply: psql "$DATABASE_URL" -f database/migrations/002_teams.sql
+
+CREATE TABLE IF NOT EXISTS teams (
+  id          UUID PRIMARY KEY DEFAULT gen_random_uuid(),
+  player_id   UUID NOT NULL REFERENCES players(id) ON DELETE CASCADE,
+  name        VARCHAR(64) NOT NULL DEFAULT 'Team',
+  slot_index  INT NOT NULL DEFAULT 0,        -- which team slot (0..N), player can have several
+  is_active   BOOLEAN NOT NULL DEFAULT FALSE, -- the team used in battle
+  created_at  TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
+  updated_at  TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
+  UNIQUE(player_id, slot_index)
+);
+
+-- Membership: which heroes are on a team and in what position (0..4).
+CREATE TABLE IF NOT EXISTS team_members (
+  team_id   UUID NOT NULL REFERENCES teams(id) ON DELETE CASCADE,
+  hero_id   UUID NOT NULL REFERENCES summoned_heroes(id) ON DELETE CASCADE,
+  position  INT NOT NULL CHECK (position >= 0 AND position < 5),
+  PRIMARY KEY (team_id, position),
+  UNIQUE (team_id, hero_id)                  -- a hero can't be on the same team twice
+);
+
+CREATE INDEX IF NOT EXISTS idx_teams_player ON teams(player_id);
+CREATE INDEX IF NOT EXISTS idx_team_members_team ON team_members(team_id);
+
+SELECT 'migration 002 (teams) applied' AS status;
diff --git a/database/migrations/003_aesthetic_tiers.sql b/database/migrations/003_aesthetic_tiers.sql
new file mode 100644
index 0000000..e6489b0
--- /dev/null
+++ b/database/migrations/003_aesthetic_tiers.sql
@@ -0,0 +1,36 @@
+-- Migration 003: expand hero tiers to the 5 aesthetic bands.
+-- Old tiers (mortal/heroic/angelic/divine) -> new aesthetic ladder.
+-- Strength order (weak->strong): medieval < xianxia_normal < xianxia_horror
+--                                 < victorian_normal < victorian_horror
+-- Idempotent / safe to re-run.
+
+-- 1) Drop the old CHECK constraint that only allowed the 4 legacy tiers.
+ALTER TABLE summoned_heroes DROP CONSTRAINT IF EXISTS summoned_heroes_tier_check;
+
+-- 2) Migrate any existing rows from old tier names to the new ladder.
+--    (mortal->medieval, heroic->xianxia_normal, angelic->victorian_normal,
+--     divine->victorian_horror; horror sub-bands are assigned at summon time.)
+UPDATE summoned_heroes SET tier = CASE tier
+  WHEN 'mortal'  THEN 'medieval'
+  WHEN 'heroic'  THEN 'xianxia_normal'
+  WHEN 'angelic' THEN 'victorian_normal'
+  WHEN 'divine'  THEN 'victorian_horror'
+  ELSE tier END
+WHERE tier IN ('mortal','heroic','angelic','divine');
+
+-- 3) Add the new CHECK with the 5 aesthetic tiers.
+ALTER TABLE summoned_heroes ADD CONSTRAINT summoned_heroes_tier_check
+  CHECK (tier IN ('medieval','xianxia_normal','xianxia_horror','victorian_normal','victorian_horror'));
+
+-- 4) Optional: a numeric strength rank so battle/sorting can compare tiers
+--    without hardcoding the string order everywhere.
+ALTER TABLE summoned_heroes ADD COLUMN IF NOT EXISTS tier_rank INT NOT NULL DEFAULT 1;
+UPDATE summoned_heroes SET tier_rank = CASE tier
+  WHEN 'medieval'         THEN 1
+  WHEN 'xianxia_normal'   THEN 2
+  WHEN 'xianxia_horror'   THEN 3
+  WHEN 'victorian_normal' THEN 4
+  WHEN 'victorian_horror' THEN 5
+  ELSE 1 END;
+
+SELECT 'migration 003 (aesthetic tiers) applied' AS status;
