+// api/team.ts
+// Hero team/party management. A player arranges up to 5 owned heroes into
+// teams; one team is "active" for battle.
+//
+// POST { playerId, action:"get", slot?:0 }          -> a team + its members
+// POST { playerId, action:"save", slot, name?, heroIds:[...] } -> set members
+// POST { playerId, action:"setActive", slot }        -> mark a team active
+// POST { playerId, action:"list" }                   -> all of the player's teams
+
+import { VercelRequest, VercelResponse } from "@vercel/node";
+import { getPool } from "./_db";
+
+function cors(res: VercelResponse) {
+  res.setHeader("Access-Control-Allow-Origin", "*");
+  res.setHeader("Access-Control-Allow-Methods", "POST, OPTIONS");
+  res.setHeader("Access-Control-Allow-Headers", "Content-Type");
+}
+
+async function ensureTeam(client: any, playerId: string, slot: number, name?: string) {
+  const q = await client.query(
+    `INSERT INTO teams (player_id, slot_index, name)
+     VALUES ($1, $2, COALESCE($3,'Team '|| ($2+1)))
+     ON CONFLICT (player_id, slot_index) DO UPDATE
+       SET name = COALESCE($3, teams.name), updated_at = CURRENT_TIMESTAMP
+     RETURNING id, name, slot_index, is_active`,
+    [playerId, slot, name || null]
+  );
+  return q.rows[0];
+}
+
+export default async (req: VercelRequest, res: VercelResponse) => {
+  cors(res);
+  if (req.method === "OPTIONS") return res.status(200).end();
+  if (req.method !== "POST") return res.status(405).json({ error: "Method not allowed" });
+
+  const { playerId, action } = req.body || {};
+  if (!playerId) return res.status(400).json({ error: "playerId required" });
+  const pool = getPool();
+
+  try {
+    if (action === "list") {
+      const q = await pool.query(
+        `SELECT t.id, t.name, t.slot_index, t.is_active,
+                COUNT(tm.hero_id)::int AS member_count
+           FROM teams t LEFT JOIN team_members tm ON tm.team_id = t.id
+          WHERE t.player_id = $1
+          GROUP BY t.id ORDER BY t.slot_index`,
+        [playerId]
+      );
+      return res.status(200).json({ teams: q.rows });
+    }
+
+    if (action === "get") {
+      const slot = Number(req.body.slot ?? 0);
+      const t = await pool.query(
+        `SELECT id, name, slot_index, is_active FROM teams WHERE player_id=$1 AND slot_index=$2`,
+        [playerId, slot]
+      );
+      if (!t.rowCount) return res.status(200).json({ team: null, members: [] });
+      const members = await pool.query(
+        `SELECT tm.position, h.id, h.class_name, h.tier, h.rarity,
+                h.health, h.attack, h.defense, h.alignment, h.element
+           FROM team_members tm JOIN summoned_heroes h ON h.id = tm.hero_id
+          WHERE tm.team_id = $1 ORDER BY tm.position`,
+        [t.rows[0].id]
+      );
+      return res.status(200).json({ team: t.rows[0], members: members.rows });
+    }
+
+    if (action === "save") {
+      const slot = Number(req.body.slot ?? 0);
+      const heroIds: string[] = Array.isArray(req.body.heroIds) ? req.body.heroIds.slice(0, 5) : [];
+      const name = req.body.name;
+      const client = await pool.connect();
+      try {
+        await client.query("BEGIN");
+        const team = await ensureTeam(client, playerId, slot, name);
+        // verify all heroes belong to this player (no injecting others' heroes)
+        if (heroIds.length) {
+          const owned = await client.query(
+            `SELECT id FROM summoned_heroes WHERE player_id=$1 AND id = ANY($2::uuid[])`,
+            [playerId, heroIds]
+          );
+          const ownedSet = new Set(owned.rows.map((r: any) => r.id));
+          const filtered = heroIds.filter(id => ownedSet.has(id));
+          // rewrite membership
+          await client.query(`DELETE FROM team_members WHERE team_id=$1`, [team.id]);
+          for (let pos = 0; pos < filtered.length; pos++) {
+            await client.query(
+              `INSERT INTO team_members (team_id, hero_id, position) VALUES ($1,$2,$3)`,
+              [team.id, filtered[pos], pos]
+            );
+          }
+        } else {
+          await client.query(`DELETE FROM team_members WHERE team_id=$1`, [team.id]);
+        }
+        await client.query("COMMIT");
+        return res.status(200).json({ saved: true, teamId: team.id, slot });
+      } catch (e: any) {
+        try { await client.query("ROLLBACK"); } catch {}
+        return res.status(500).json({ error: "save failed", detail: String(e?.message || e) });
+      } finally { client.release(); }
+    }
+
+    if (action === "setActive") {
+      const slot = Number(req.body.slot ?? 0);
+      const client = await pool.connect();
+      try {
+        await client.query("BEGIN");
+        await ensureTeam(client, playerId, slot);
+        await client.query(`UPDATE teams SET is_active=FALSE WHERE player_id=$1`, [playerId]);
+        await client.query(`UPDATE teams SET is_active=TRUE WHERE player_id=$1 AND slot_index=$2`, [playerId, slot]);
+        await client.query("COMMIT");
+        return res.status(200).json({ active: slot });
+      } catch (e: any) {
+        try { await client.query("ROLLBACK"); } catch {}
+        return res.status(500).json({ error: "setActive failed", detail: String(e?.message || e) });
+      } finally { client.release(); }
+    }
+
+    return res.status(400).json({ error: "unknown action" });
+  } catch (e: any) {
+    return res.status(500).json({ error: "team op failed", detail: String(e?.message || e) });
+  }
+};
